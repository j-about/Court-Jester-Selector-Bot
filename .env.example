# ============================================================================
# Court Jester Selector Bot — environment template
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in the Required section. Never commit `.env`.
# Defaults shown below match `config.py`; uncomment a line only to override.
# ============================================================================

# --- Deployment (Ansible) [local-only — not sent to the server] ---
HOST_IP=192.168.1.100
HOST_USER=username
HOST_SSH_PRIVATE_KEY_FILE=~/.ssh/privatekeyfile

# --- Required (no defaults in config.py; values below are suggestions) ---
TG_BOT_TOKEN=""
POSTGRES_DB="cjsb_db"
POSTGRES_USER="cjsb_user"
POSTGRES_PASSWORD="changeme"   # change before first run

# --- Database host/port (optional; defaults shown) ---
# POSTGRES_HOST="db"
# POSTGRES_PORT=5432

# --- Admin rights (optional; defaults shown; comma-separated) ---
# TG_BOT_ADMIN_RIGHTS_CHAT_MEMBER_STATUS="creator,administrator"  # allowed: creator, administrator
# TG_BOT_ADMIN_RIGHTS_USER_IDS=""                                 # comma-separated positive integers; empty = auto-approve every new group (no human gate)

# --- Draw timing (optional; default shown) ---
# DRAW_TIMEZONE="UTC"     # IANA timezone (e.g. "Europe/Paris") used to decide when the civil day (and therefore a new draw) rolls over

# --- Observability (optional) ---
# SENTRY_DSN=""

# --- Weights & pagination (optional; defaults shown) ---
# MIN_WEIGHT=1            # >= 0
# MAX_WEIGHT=5            # >= MIN_WEIGHT
# DEFAULT_WEIGHT=3        # within [MIN_WEIGHT, MAX_WEIGHT]
# GROUPS_PER_PAGE=5       # >= 1
# PLAYERS_PER_PAGE=5      # >= 1
# MIN_PLAYERS=10          # >= 2

# --- Command names (optional; defaults shown) ---
# Command names must match ^[a-z][a-z0-9_]{0,31}$
# PICK_PLAYER_COMMAND="crown_the_jester"
# PICK_PLAYER_COMMAND_DESCRIPTION="Crown today's jester."
# SHOW_LEADERBOARD_COMMAND="court_leaderboard"
# SHOW_LEADERBOARD_COMMAND_DESCRIPTION="View the court rankings."
# SHOW_PERSONAL_STATS_COMMAND="my_jester_stats"
# SHOW_PERSONAL_STATS_COMMAND_DESCRIPTION="Check your jester stats."

# --- Message templates (optional; defaults are defined in `config.py`) ---
# Uncomment below to override. Required placeholders (MUST be kept):
#   PICK_PLAYER_PICKED_PLAYER_MESSAGE      -> {username}
#   LEADERBOARD_RANK_MESSAGE               -> {rank}, {username}
#   PERSONAL_STATS_MESSAGE                 -> {draw_count}
# Optional placeholders (included only if you want them substituted):
#   NOT_ENOUGH_PLAYERS_MESSAGE              -> {min_players}
#   LEADERBOARD_RANK_MESSAGE                -> {draw_count}
#   PERSONAL_STATS_NO_PICKED_PLAYER_MESSAGE -> {username}
#   PERSONAL_STATS_MESSAGE                  -> {username}, {rank}
# NON_APPROVED_GROUP_MESSAGE=""
# NOT_ENOUGH_PLAYERS_MESSAGE=""
# PICK_PLAYER_PICKED_PLAYER_MESSAGE=""
# LEADERBOARD_NOT_ENOUGH_PICKED_PLAYERS_MESSAGE=""
# LEADERBOARD_INTRO_MESSAGE=""
# LEADERBOARD_RANK_MESSAGE=""
# LEADERBOARD_OUTRO_MESSAGE=""
# PERSONAL_STATS_NO_PICKED_PLAYER_MESSAGE=""
# PERSONAL_STATS_MESSAGE=""